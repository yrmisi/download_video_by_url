                "name": "Annotations & Alerts",
                "type": "dashboard"
            }
        ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "title": "FastAPI RPS (Requests per Second)",
            "type": "stat",
            "datasource": "prometheus",
            "targets": [
                {
                    "datasource": "prometheus",
                    "editorMode": "code",
                    "expr": "sum(rate(http_requests_total[2m]))",
                    "range": true,
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    },
                    "unit": "reqps"
                },
                "overrides": []
            },
            "options": {
                "graphMode": "area",
                "justifyMode": "auto",
                "orientation": "auto",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "textMode": "valueAndName"
            }
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 0
            },
            "id": 2,
            "title": "Average Response Time",
            "type": "stat",
            "datasource": "prometheus",
            "targets": [
                {
                    "datasource": "prometheus",
                    "editorMode": "code",
                    "expr": "sum(rate(http_request_duration_seconds_sum[2m])) / sum(rate(http_request_duration_seconds_count[2m]))",
                    "range": true,
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 0.5
                            },
                            {
                                "color": "red",
                                "value": 1.5
                            }
                        ]
                    },
                    "unit": "s"
                },
                "overrides": []
            },
            "options": {
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "textMode": "value"
            }
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 4
            },
            "id": 3,
            "title": "HTTP Requests by Status Code",
            "type": "timeseries",
            "datasource": "prometheus",
            "targets": [
                {
                    "datasource": "prometheus",
                    "editorMode": "code",
                    "expr": "sum(rate(http_requests_total[2m])) by (status)",
                    "legendFormat": "Status {{status}}",
                    "range": true,
                    "refId": "A"
                }
            ],
            "options": {
                "legend": {
                    "calcs": [],
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            }
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 4
            },
            "id": 4,
            "title": "HTTP Requests by Path",
            "type": "timeseries",
            "datasource": "prometheus",
            "targets": [
                {
                    "datasource": "prometheus",
                    "editorMode": "code",
                    "expr": "sum(rate(http_requests_total[2m])) by (handler)",
                    "legendFormat": "{{handler}}",
                    "range": true,
                    "refId": "A"
                }
            ],
            "options": {
                "legend": {
                    "calcs": [],
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            }
        }
    ],
    "refresh": "5s",
    "schemaVersion": 39,
    "tags": [
        "fastapi"
    ],
    "style": "dark",
